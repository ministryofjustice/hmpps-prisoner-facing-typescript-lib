{
  "name": "@ministryofjustice/hmpps-prisoner-auth",
  "version": "0.0.1",
  "description": "Middleware for providing authentication against Launchpad Auth",
  "author": "hmpps-launchpad-devs",
  "license": "MIT",
  "homepage": "https://github.com/ministryofjustice/hmpps-prisoner-facing-typescript-lib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ministryofjustice/hmpps-prisoner-facing-typescript-lib.git"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "files": [
    "*.md",
    "dist/**/*",
    "src/**/*"
  ],
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "rollup -c rollup.config.ts --bundleConfigAsCjs",
    "clean": "rm -rf ./dist/",
    "test": "jest",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "check-for-updates": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@ministryofjustice/eslint-config-hmpps": "1.0.3",
    "@types/passport-openidconnect": "^0.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/superagent": "^8.1.9",
    "jsonwebtoken": "^9.0.3"
  },
  "dependencies": {
    "@ministryofjustice/hmpps-rest-client": "^1.1.0",
    "passport-openidconnect": "^0.1.2",
    "superagent": "^10.3.0"
  },
  "peerDependencies": {}
}
