    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "check-for-updates": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@types/bunyan": "^1.8.11",
    "@types/express": "^5.0.6",
    "@types/superagent": "^8.1.9",
    "nock": "^14.0.11",
    "redis": "^5.11.0"
  },
  "dependencies": {
    "@ministryofjustice/hmpps-rest-client": "^1.1.0"
  },
  "peerDependencies": {}
}
